{
  "name": "@mental-load/backend",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/packages/backend/src/index.js",
    "worker": "tsx watch src/workers/reminder-worker.ts",
    "start:worker": "node dist/packages/backend/src/workers/reminder-worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.2",
    "@mental-load/contracts": "0.1.0",
    "bullmq": "^5.56.1",
    "fastify": "^5.0.0",
    "node-ical": "^0.20.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.0",
    "rrule": "^2.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
