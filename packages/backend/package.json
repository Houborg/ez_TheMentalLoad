{
  "name": "@mental-load/backend",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/packages/backend/src/index.js",
    "worker": "tsx watch src/workers/reminder-worker.ts",
    "start:worker": "node dist/packages/backend/src/workers/reminder-worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.2",
    "@mental-load/contracts": "0.1.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.56.1",
    "fastify": "^5.0.0",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.8",
    "node-ical": "^0.20.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.0",
    "rrule": "^2.8.1",
    "tsdav": "^2.2.2",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.2",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "5.6.3"
  }
}
