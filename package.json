{
  "name": "mental-load",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:worker",
    "dev:backend": "npm --workspace @mental-load/backend run dev",
    "dev:frontend": "npm --workspace @mental-load/frontend run dev",
    "dev:worker": "npm --workspace @mental-load/backend run worker",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:integration": "npm --workspace @mental-load/backend run test",
    "test:e2e": "npm --workspace @mental-load/e2e run test",
    "qa": "npm-run-all test:integration test:e2e",
    "qa:full": "npm-run-all build typecheck qa"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
