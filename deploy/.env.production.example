# ============================================================
# ez_TheMentalLoad — Production Environment Template
# ============================================================
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Fill in every CHANGE_ME value before deploying
# 3. NEVER commit .env.production to git
# ============================================================

# ── Server / Traefik ─────────────────────────────────────────
# The domain suffix used by Traefik (matches your ez_testbench .env)
# Example: BASE_DOMAIN=home.myserver.com  → app at mentalload.home.myserver.com
# Leave blank for now if you don't have a domain yet.
BASE_DOMAIN=CHANGE_ME

# ── Database ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ── Persistence ───────────────────────────────────────────────
PERSISTENCE_DRIVER=postgres
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/mental_load
REDIS_URL=redis://redis:6379

# ── Outgoing Email (SMTP) ─────────────────────────────────────
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_FROM=CHANGE_ME
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ── Incoming Email (IMAP) ─────────────────────────────────────
# Only needed if you use the invite-mail feature
IMAP_HOST=CHANGE_ME
IMAP_PORT=993
IMAP_USER=CHANGE_ME
IMAP_PASS=CHANGE_ME
IMAP_SECURE=true

# ── AI (Ollama) ───────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── App ───────────────────────────────────────────────────────
DEFAULT_TIMEZONE=Europe/Copenhagen
REMINDER_TEST_EMAIL=CHANGE_ME

# ── Web Push / VAPID ──────────────────────────────────────────
# Generate a key pair once with:
#   npx web-push generate-vapid-keys
# Then paste the two values below.
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:CHANGE_ME

# ── UI “Update production” button ─────────────────────────────────
UPDATE_WEBHOOK_SECRET=CHANGE_ME
